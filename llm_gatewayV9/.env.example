# LabLens + LLM Gateway V9 — environment variable template
# Copy this file to .env and fill in your keys.
# .env is git-ignored. This file (.env.example) is safe to commit.
#
# llm_gatewayV9 loads this file from the project root on startup.
# llm_client.py (in code/) also reads these vars directly when running
# without the gateway.

# ── Required — at least GEMINI_API_KEY must be set ───────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

# ── Optional LLM fallbacks ────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_MODEL=gemma4:e4b
OLLAMA_URL=http://localhost:11434

CEREBRAS_API_KEY=...
CEREBRAS_MODEL=llama3.1-70b

NVIDIA_API_KEY=...
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

OPEN_ROUTER_API_KEY=...
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

GITHUB_ACCESS_TOKEN=ghp_...
GITHUB_MODEL=openai/gpt-4.1-mini

# ── MCP / search (used by code/ agent tools) ─────────────────────────────────
TAVILY_API_KEY=tvly-dev-...


# ── LLM Gateway V3 ──────────────────────────────────────────────────────────
GATEWAY_V3_PORT=8101

# ── Provider keys — fill in the ones you have ───────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

OLLAMA_MODEL=gemma4:e4b
OLLAMA_URL=http://localhost:11434

# ── MCP server keys ─────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-dev-...

# ── Placeholder keys (fill if available) ────────────────────────────────────
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=deepseek-ai/deepseek-v4-flash

CEREBRAS_API_KEY=csk-...
CEREBRAS_MODEL=gpt-oss-120b

OPEN_ROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

GITHUB_ACCESS_TOKEN=ghp_...
GITHUB_MODEL=openai/gpt-4.1-mini

# ── Worker failover order ────────────────────────────────────────────────────
# Original default: ollama,gemini,nvidia,groq,cerebras,openrouter,github
# Updated: Gemini first (large context), Cerebras (60K TPM free), Groq, NVIDIA,
# OpenRouter (free models), GitHub (free), Ollama last (local fallback)
LLM_ORDER=cerebras,gemini,github,openrouter,groq,nvidia,ollama

# ── Router pool (routing-decision LLMs — smaller/faster) ────────────────────
# Groq in 722s backoff — github(Phi-4-mini) and nvidia(nano) are fast and fresh
ROUTER_ORDER=groq,nvidia
ROUTER_GROQ_MODEL=llama-3.3-70b-versatile
ROUTER_NVIDIA_MODEL=nvidia/llama-3.1-nemotron-nano-8b-v1
ROUTER_CEREBRAS_MODEL=gpt-oss-120b
ROUTER_GITHUB_MODEL=microsoft/Phi-4-mini-instruct
