# computer-use-agent -- environment template
# Copy to .env (git-ignored) and fill in what you have.
#
# This single file is read by both code/ (config.py) and the bundled
# llm_gatewayV9/ (which loads .env from its own working directory --
# since it's launched with cwd=llm_gatewayV9/, point it at the repo
# root's .env via a symlink/copy if you run it standalone outside of
# code/gateway.py's auto-start, or just keep one .env at repo root and
# let gateway.py's subprocess pick it up -- main.py loads its .env
# relative to itself, so for a fully standalone gateway run, copy this
# file to llm_gatewayV9/.env too).

# ── LLM provider keys -- need at least one ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-70b

NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

OPEN_ROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

GITHUB_ACCESS_TOKEN=
GITHUB_MODEL=openai/gpt-4.1-mini

OLLAMA_MODEL=gemma2:9b
OLLAMA_URL=http://localhost:11434

# ── Failover order -- edit this, not the code, to change provider priority ──
LLM_ORDER=cerebras,gemini,github,openrouter,groq,nvidia,ollama

# ── Gateway server ───────────────────────────────────────────────────────────
GATEWAY_V9_PORT=8109
LLM_GATEWAY_V9_URL=http://localhost:8109

# ── cua-driver ────────────────────────────────────────────────────────────────
CUA_DRIVER_BIN=cua-driver

# ── Task 1: Calculator ───────────────────────────────────────────────────────
CALCULATOR_APP_NAME=Calculator
CALCULATOR_EXPRESSION=5000000*8.5/100/12

# ── Task 2: VS Code ───────────────────────────────────────────────────────────
VSCODE_APP_NAME=Visual Studio Code
VSCODE_BUNDLE_ID=com.microsoft.VSCode
ELECTRON_DEBUG_PORT=9222

# ── Task 3: MS Paint ──────────────────────────────────────────────────────────
PAINT_APP_NAME=Paint
PAINT_BIN=mspaint.exe
PAINT_DRAW_TARGET=a 5-pointed star
PAINT_MAX_STEPS=12
